{
  "name": "citynight",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20.11.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "npm run db:migrate && next build",
    "//build:analyze": "run with `ANALYZE=1 npm run build` (bash) or `$env:ANALYZE='1'; npm run build` (PowerShell)",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx db/migrate.ts",
    "db:studio": "drizzle-kit studio",
    "test:seo": "node scripts/tests/seo-smoke.mjs",
    "test:integrity": "node scripts/seed/tests/enrichment-writer.test.js && node scripts/seed/tests/design-writer.test.js && node scripts/tests/owner-edit.test.mjs && node scripts/tests/photos-check.test.mjs && node scripts/tests/gates.test.mjs && node scripts/tests/booking-engine.test.mjs && node scripts/tests/shop-engine.test.mjs && node scripts/tests/crm-engine.test.mjs && node scripts/tests/articles-engine.test.mjs",
    "test:e2e": "playwright test",
    "test:lighthouse": "node scripts/tests/lighthouse.mjs",
    "test:crawl": "node scripts/tests/crawl-reachable.mjs",
    "translations:audit": "node scripts/translations/audit.mjs",
    "translations:backfill": "node scripts/translations/backfill.js"
  },
  "dependencies": {
    "@next/mdx": "^16.2.6",
    "@stripe/react-stripe-js": "^3.0.0",
    "@stripe/stripe-js": "^4.10.0",
    "@types/archiver": "^7.0.0",
    "archiver": "^7.0.1",
    "better-sqlite3": "^11.3.0",
    "drizzle-orm": "^0.45.2",
    "next": "^16.2.6",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "stripe": "^22.1.1"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@next/bundle-analyzer": "^16.2.6",
    "@next/eslint-plugin-next": "^16.2.6",
    "@playwright/test": "^1.60.0",
    "@tailwindcss/postcss": "^4.0.0",
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "dotenv": "^16.4.5",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.6",
    "postcss": "^8.4.47",
    "tailwindcss": "^4.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
