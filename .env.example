# --- SQLite (Hostinger LAW: this path is OUTSIDE the deploy directory) ---
# On Hostinger production, point this at a persistent dir like /home/uXXX/persistent/citynight.sqlite
# Locally, use a relative path; .sqlite files are gitignored.
DATABASE_PATH=./citynight.local.sqlite

# --- Owner-uploaded photos (same rule: OUTSIDE the deploy directory on Hostinger) ---
# On Hostinger production: /home/uXXX/persistent/citynight-uploads/
# Locally: relative path (gitignored). Served via /api/uploads/[...path] route.
UPLOADS_PATH=./uploads

# --- Unsplash (stock photos for city guides; free 50 req/hour) ---
# Sign up at https://unsplash.com/developers → create an app → copy Access Key.
UNSPLASH_ACCESS_KEY=

# --- Google ---
# The Maps JS / Maps Static key MUST be in the browser; mitigate with HTTP-referrer
# restrictions on the key (Google Cloud Console). MUST differ from the Places key.
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
# Server-only key for Places API (New); never exposed to the browser.
GOOGLE_PLACES_API_KEY=

# --- Anthropic (enrichment: descriptions only, Haiku 4.5 via Message Batches) ---
ANTHROPIC_API_KEY=

# --- Stripe (Elements UI + Billing engine + webhook -> SQLite) ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# Stripe Price IDs for the locked tiers (created in Stripe dashboard once).
STRIPE_PRICE_FEATURED_MONTHLY=
STRIPE_PRICE_AD_SECTION_MONTHLY=
# SaaS sites — Phase G1. €19/mo recurring + €190 one-time (Atelier ZIP).
# Create in Stripe Dashboard → Products. Set both currencies to EUR.
STRIPE_PRICE_SITE_MONTHLY=
STRIPE_PRICE_SITE_ZIP=

# --- Magic-link email (Resend) ---
EMAIL_FROM="citynight.gr <hello@citynight.gr>"
EMAIL_API_KEY=

# --- Google OAuth (optional; sign-in still works without it via magic-link) ---
# Google Cloud Console -> APIs & Services -> Credentials -> Create OAuth 2.0 Client ID
# Application type: Web application
# Authorized redirect URIs: http://localhost:3000/api/auth/google/callback (dev)
#                           https://citynight.gr/api/auth/google/callback   (prod)
# IMPORTANT: keep the SECRET out of any NEXT_PUBLIC_ var. Rotate immediately if leaked.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# --- CMP (consent mode v2; Google-certified) ---
NEXT_PUBLIC_CMP_SITE_ID=

# --- AdSense (publisher client id, ca-pub-...) ---
NEXT_PUBLIC_ADSENSE_CLIENT=

# --- Site ---
NEXT_PUBLIC_SITE_URL=https://citynight.gr

# --- Hero background video (YouTube id, e.g. dQw4w9WgXcQ). Optional —
# if unset, the hero falls back to the still image. Replace with any
# Greek nightlife / city b-roll video id. Loops + muted by default. ---
NEXT_PUBLIC_HERO_YOUTUBE_ID=

# --- Session secret (32+ random bytes, hex) ---
SESSION_SECRET=

# --- Local dev convenience: override CF-IPCountry when not behind Cloudflare ---
# Two-letter ISO code, e.g. GR, US, DE. Ignored in production.
DEV_COUNTRY_OVERRIDE=GR
